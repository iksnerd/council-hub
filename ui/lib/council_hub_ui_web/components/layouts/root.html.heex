<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Council Hub">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" href={~p"/favicon.ico"} sizes="48x48" />
    <link rel="icon" href={~p"/favicon.svg"} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={~p"/apple-touch-icon.png"} />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <meta name="theme-color" content="#1c1c20" />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=ibm-plex-sans:300,400,500,600,700|ibm-plex-mono:400,500"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-[#070b14] text-slate-200 antialiased">
    {@inner_content}
  </body>
</html>
