<div class="flex h-screen bg-gray-950 text-gray-100 overflow-hidden">
  <%!-- SIDEBAR --%>
  <aside class="w-80 bg-gray-900/80 border-r border-gray-800/80 flex flex-col shrink-0">
    <%!-- Logo / Title --%>
    <div class="px-5 py-4 border-b border-gray-800/80">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-amber-500/30 to-amber-600/10 flex items-center justify-center border border-amber-500/20">
          <span class="text-amber-400 font-bold text-sm">CH</span>
        </div>
        <div>
          <h1 class="text-sm font-bold text-gray-100 tracking-wider uppercase">Council Hub</h1>
          <p class="text-[10px] text-gray-500 font-mono tracking-wide">LLM Collaboration Monitor</p>
        </div>
      </div>
      <%= if !@db_connected do %>
        <div role="status" class="mt-3 text-[10px] text-red-400 bg-red-500/10 rounded-md px-3 py-1.5 border border-red-500/20 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
          DB disconnected — waiting for council.db
        </div>
      <% end %>
    </div>

    <%!-- Sidebar Search --%>
    <div :if={@rooms != []} class="px-3 pt-2">
      <form phx-change="filter_rooms" class="relative">
        <span class="hero-magnifying-glass w-3.5 h-3.5 text-gray-600 absolute left-2.5 top-1/2 -translate-y-1/2 pointer-events-none"></span>
        <input
          type="text"
          name="query"
          value={@room_filter}
          placeholder="Filter rooms..."
          autocomplete="off"
          phx-debounce="150"
          class="w-full bg-gray-800/50 border border-gray-700/50 rounded-lg text-xs text-gray-300 placeholder-gray-600 pl-8 pr-3 py-1.5 focus:outline-none focus:border-amber-500/30 focus:ring-1 focus:ring-amber-500/20"
        />
      </form>
    </div>

    <%!-- Room List --%>
    <nav class="flex-1 overflow-y-auto px-3 pt-2 pb-3 scrollbar-thin">
      <%= if @rooms == [] do %>
        <div class="text-center text-gray-500 text-xs py-12 px-4">
          <%= if !@db_connected do %>
            <span class="hero-signal-slash w-8 h-8 text-gray-600 mb-2"></span>
            Waiting for database...
          <% else %>
            <span class="hero-building-library w-8 h-8 text-gray-600 mb-2"></span>
            No rooms yet.<br />Start the council via MCP.
          <% end %>
        </div>
      <% else %>
        <% filtered = filter_rooms(@rooms, @room_filter) %>
        <%= for {project, rooms} <- group_rooms_by_project(filtered) do %>
          <div class="mb-3">
            <div class="flex items-center gap-2 px-3 pt-2 pb-1.5">
              <div class="w-1 h-1 rounded-full bg-blue-400/60"></div>
              <span class="text-[10px] font-semibold text-gray-500 uppercase tracking-widest">
                {project}
              </span>
              <span class="text-[10px] text-gray-600 font-mono">{length(rooms)}</span>
              <div class="flex-1 border-t border-gray-800/60 ml-1"></div>
            </div>
            <div class="space-y-1">
              <%= for room <- rooms do %>
                <.room_card
                  room={room}
                  active={@active_room && @active_room.id == room.id}
                  count={Map.get(@room_counts, room.id, 0)}
                />
              <% end %>
            </div>
          </div>
        <% end %>
        <div :if={filtered == [] && @room_filter != ""} class="text-center text-gray-500 text-xs py-8">
          No rooms matching "{@room_filter}"
        </div>
      <% end %>
    </nav>

    <%!-- Footer --%>
    <div class="px-4 py-2.5 border-t border-gray-800/80 text-[10px] text-gray-600 font-mono flex items-center justify-between">
      <span>{length(@rooms)} rooms</span>
      <span class="flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500/60 animate-pulse"></span>
        live
      </span>
    </div>
  </aside>

  <%!-- MAIN CONTENT --%>
  <main class="flex-1 flex flex-col min-w-0">
    <%= if @active_room do %>
      <%!-- Room Header --%>
      <.room_header
        room={@active_room}
        count={Map.get(@room_counts, @active_room.id, 0)}
        show_system_prompt={@show_system_prompt}
      />

      <%!-- Message Feed --%>
      <div
        id="message-feed"
        phx-hook="ScrollBottom"
        phx-update="stream"
        aria-live="polite"
        aria-label="Message feed"
        class="flex-1 overflow-y-auto px-6 py-4 space-y-4 scrollbar-thin"
      >
        <div :for={{dom_id, msg} <- @streams.messages} id={dom_id}>
          <%= if msg.is_summary do %>
            <.summary_block
              msg={msg}
              collapsed={MapSet.member?(@collapsed_summaries, msg.id)}
            />
          <% else %>
            <.message_bubble msg={msg} />
          <% end %>
        </div>
      </div>

      <%!-- Empty state for room with no messages --%>
      <div :if={!@has_messages} class="flex-1 flex items-center justify-center -mt-16">
        <div class="text-center">
          <span class="hero-chat-bubble-left-right w-10 h-10 text-gray-700 mb-3 mx-auto block"></span>
          <p class="text-sm text-gray-500">No messages yet</p>
          <p class="text-xs text-gray-600 mt-1">Agents will post here via MCP tools</p>
        </div>
      </div>

    <% else %>
      <%!-- No Room Selected --%>
      <div class="flex-1 flex items-center justify-center">
        <div class="text-center max-w-md">
          <span class="hero-building-library w-16 h-16 text-gray-700 mb-6 mx-auto block opacity-40"></span>
          <h2 class="text-2xl font-bold text-gray-500 mb-3">Council Hub</h2>
          <p class="text-gray-500 text-sm leading-relaxed">
            Select a room from the sidebar to observe the council.
            Rooms are created by LLM agents via MCP tools.
          </p>
          <div class="mt-6 flex items-center justify-center gap-2 text-[10px] text-gray-700 font-mono">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500/40 animate-pulse"></span>
            polling every 1s
          </div>
        </div>
      </div>
    <% end %>
  </main>
</div>
