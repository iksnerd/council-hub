        G["Gemini CLI"]
        C["Claude Code"]
        GM["Local Gemma (Librarian)"]
    end

    subgraph Server ["The Artifact (Council Hub - Dumb Server)"]
        direction TB
        subgraph DKR ["Dynamic Knowledge Repository (SQLite)"]
            LOG[("Deliberation Log <br/> (Immutable UUID v7 History)")]
            SYN{{"Synthesis Layer <br/> (Compiled Wiki Articles)"}}
            FTS5["FTS5 Search Index <br/> (The 'Instant' Index)"]
        end
        
        J["Janitor.go <br/> (Knowledge Linter)"]
    end

    %% Interactions
    G -- "1. Deliberate" --> LOG
    C -- "1. Deliberate" --> LOG
    
    GM -- "2. Read Log" --> LOG
    GM -- "3. Compile" --> SYN
    
    J -- "4. SQL Audit" --> LOG
    J -- "5. Flag Health" --> DKR
    
    DKR -- "6. Knowledge Digest" --> G
    DKR -- "6. Knowledge Digest" --> C

    %% Concept Mappings
    classDef karpathy fill:#f9f,stroke:#333,stroke-width:2px;
    classDef engelbart fill:#00d2ff,stroke:#333,stroke-width:2px;
    
    class SYN,J,GM karpathy;
    class LOG,FTS5,DKR engelbart;
